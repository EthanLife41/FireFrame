DASHBOARD_PASSWORD=0000 # Change this to a strong 4-digit PIN to protect your dashboard.
SESSION_SECRET=change-this-random-string
HOST=0.0.0.0
PORT=8765

# --- Calendar (macOS-first) ---
# none | demo | ics | apple
CALENDAR_SOURCE=demo
# Used when CALENDAR_SOURCE=ics. Either a local .ics file path OR an https URL
# (e.g. the Apple/Google "secret address in iCal format"). Treat a URL as a
# credential: keep it here, never commit it.
CALENDAR_ICS_PATH=
# Optional: multiple .ics files at once, separated by ":" (macOS/Linux).
CALENDAR_ICS_PATHS=
CALENDAR_UPCOMING_DAYS=7
# Cache window for calendar reads, in seconds (keeps osascript calls infrequent).
CALENDAR_REFRESH_SECONDS=300

# --- Photos ---
# Optional: point at a folder outside the repo to keep your pictures private.
PHOTOS_DIR=
PHOTO_INTERVAL_SECONDS=30

# --- Bluetooth ---
# Connect/disconnect needs the optional 'blueutil' tool. Set to 0 to disable those actions.
BLUETOOTH_ALLOW_CONNECT=1
# Optional path to blueutil. Leave empty to auto-detect (./bin/blueutil, then PATH).
BLUEUTIL_PATH=

# --- Timers ---
# Sound for the completion notification (a name from /System/Library/Sounds).
# Leave blank for a silent banner.
TIMER_SOUND=Glass

# --- Weather (optional) ---
# Off by default. Set to 1 and create a Shortcut that prints the weather string.
WEATHER_ENABLED=0
WEATHER_SHORTCUT="FireFrame Weather"

# --- Tasks ---
# FireFrame tasks are scheduled Apple Calendar blocks sized by importance.
# Leave TASK_DEFAULT_CALENDAR blank to auto-pick a calendar named like "Tasks",
# else the system default. Set it to a calendar name to force that target.
TASK_DEFAULT_CALENDAR=
TASK_REGULAR_DURATION_MINUTES=60
TASK_IMPORTANT_DURATION_MINUTES=240
# How far ahead the Calendar tab's Tasks list looks (the Home card shows only the next few).
TASK_UPCOMING_LOOKAHEAD_DAYS=365
# Where "Add Task" collects input: "dashboard" (the tablet form) or "mac_prompt"
# (native dialogs on the Mac). Also switchable from the Settings page.
TASK_INPUT_LOCATION=dashboard
