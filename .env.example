DASHBOARD_PASSWORD=change-me
SESSION_SECRET=change-this-random-string
HOST=0.0.0.0
PORT=8765

# --- Calendar (macOS-first) ---
# none | demo | ics | apple
CALENDAR_SOURCE=none
# Used when CALENDAR_SOURCE=ics. Either a local .ics file path OR an https URL
# (e.g. the Apple/Google "secret address in iCal format"). Treat a URL as a
# credential: keep it here, never commit it.
CALENDAR_ICS_PATH=
# Optional: multiple .ics files at once, separated by ":" (macOS/Linux).
CALENDAR_ICS_PATHS=
CALENDAR_UPCOMING_DAYS=7
# Cache window for calendar reads, in seconds (keeps osascript calls infrequent).
CALENDAR_REFRESH_SECONDS=300

# --- Photos ---
# Optional: point at a folder outside the repo to keep your pictures private.
PHOTOS_DIR=
PHOTO_INTERVAL_SECONDS=30

# --- Bluetooth ---
# Connect/disconnect needs the optional 'blueutil' tool. Set to 0 to disable those actions.
BLUETOOTH_ALLOW_CONNECT=1
# Optional path to blueutil. Leave empty to auto-detect (./bin/blueutil, then PATH).
BLUEUTIL_PATH=
